#         fastcgi_param  SCRIPT_FILENAME  /usr/local/www/nginx/gestao/index.php;
#         # SCRIPT_NAME garante que o portal detecte o prefixo /gestao corretamente.
#         fastcgi_param  SCRIPT_NAME      /gestao/index.php;
