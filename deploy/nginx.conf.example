# Exemplo de config do Nginx para o Portal de Gestao de Dados.
# Copie para /etc/nginx/sites-available/meu-portal, ajuste os pontos
# marcados com "AJUSTE AQUI" e habilite com:
#   sudo ln -s /etc/nginx/sites-available/meu-portal /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# Este arquivo cobre dois cenarios -- escolha o que se aplica:
#
#   A) Portal na raiz do dominio  -> https://portal.minhaempresa.com.br/
#   B) Portal em subdiretorio     -> https://intranet.empresa.com.br/gestao/
#      (tipico no FreeBSD e em servidores compartilhados)
#
# Notas tecnicas:
#   - Usa SCRIPT_FILENAME com caminho absoluto fixo (cenario B) em vez de
#     $document_root/$realpath_root para evitar ambiguidade em servidores
#     FreeBSD onde /usr/local/www/nginx pode ser symlink para nginx-dist.
#   - SCRIPT_NAME fixo garante que caminhoBaseApp() detecte o prefixo
#     correto (/gestao) via $_SERVER['SCRIPT_NAME'].
#   - "index index.php" dentro do location evita 403 Forbidden quando
#     try_files encontra o diretorio antes de chegar no index.php.

# =============================================================================
# CENARIO A -- portal na raiz do dominio (https://portal.minhaempresa.com.br/)
# =============================================================================
server {
    listen 80;
    listen [::]:80;

    # AJUSTE AQUI: dominio real do portal.
    server_name portal.minhaempresa.com.br;

    # AJUSTE AQUI: caminho absoluto onde o projeto foi copiado no servidor.
    root  /var/www/meu-portal;
    index index.php;

    # Bloqueia acesso direto as pastas internas.
    location ^~ /conf/    { deny all; }
    location ^~ /backend/ { deny all; }
    location ^~ /db/      { deny all; }
    location ^~ /deploy/  { deny all; }
    location ~ /\.git     { deny all; }
    location ~ ^/(README|DEPLOY)\.md$ { deny all; }

    location / {
        index     index.php;
        try_files $uri /index.php$is_args$args;
    }

    location ~ \.php$ {
        include        fastcgi_params;
        # Cenario A: portal na raiz -- $document_root + $fastcgi_script_name OK.
        fastcgi_param  SCRIPT_FILENAME  $document_root$fastcgi_script_name;

        # AJUSTE AQUI: socket do PHP-FPM (confira a versao com "php -v").
        # Linux (Ubuntu/Debian): unix:/run/php/php8.1-fpm.sock
        # FreeBSD:               127.0.0.1:9000
        fastcgi_pass   unix:/run/php/php8.1-fpm.sock;
    }

    # HSTS (so ative depois que o HTTPS estiver funcionando e validado).
    # add_header Strict-Transport-Security "max-age=86400; includeSubDomains" always;

    client_max_body_size 10m;
    access_log /var/log/nginx/meu-portal.access.log;
    error_log  /var/log/nginx/meu-portal.error.log;
}


# =============================================================================
# CENARIO B -- portal em subdiretorio (https://intranet.empresa.com.br/gestao/)
# =============================================================================
# Use quando o Nginx ja serve outros sites/apps na mesma porta/dominio.
# Exemplo FreeBSD: arquivos em /usr/local/www/nginx/gestao/ e acesso via
# http://IP/gestao/.

